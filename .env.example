# Instagram Credentials (for fetching saved videos)
INSTAGRAM_USERNAME=your_username
INSTAGRAM_PASSWORD=your_password

# OpenAI API Key (optional - for better recipe extraction)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Whisper model size: tiny, base, small, medium, large
# "base" is recommended (good balance of speed/accuracy)
WHISPER_MODEL=base
